# Optional: provide a GitHub token to reduce anonymous API rate-limit risk
GITHUB_TOKEN=

# Optional: comma-separated ghproxy-style GitHub mirror prefixes.
# Example: GITHUB_MIRRORS=https://ghproxy.net
GITHUB_MIRRORS=

# Optional: override the default auto-sync data directory with your own local path
GAMEDATA_PATH=

# Optional: reserved for future story data features
STORYJSON_PATH=
